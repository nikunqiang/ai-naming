[
  { "chapter": "学而", "content": "学而时习之，不亦说乎" },
  { "chapter": "学而", "content": "有朋自远方来，不亦乐乎" },
  { "chapter": "学而", "content": "人不知而不愠，不亦君子乎" },
  { "chapter": "学而", "content": "君子务本，本立而道生" },
  { "chapter": "学而", "content": "孝弟也者，其为仁之本与" },
  { "chapter": "学而", "content": "巧言令色，鲜矣仁" },
  { "chapter": "学而", "content": "吾日三省吾身" },
  { "chapter": "学而", "content": "为人谋而不忠乎" },
  { "chapter": "学而", "content": "与朋友交而不信乎" },
  { "chapter": "学而", "content": "传不习乎" },
  { "chapter": "学而", "content": "道千乘之国，敬事而信" },
  { "chapter": "学而", "content": "节用而爱人，使民以时" },
  { "chapter": "学而", "content": "弟子入则孝，出则弟" },
  { "chapter": "学而", "content": "行有余力，则以学文" },
  { "chapter": "学而", "content": "贤贤易色" },
  { "chapter": "学而", "content": "温良恭俭让以得之" },
  { "chapter": "学而", "content": "父在观其志，父没观其行" },
  { "chapter": "学而", "content": "礼之用，和为贵" },
  { "chapter": "学而", "content": "信近于义，言可复也" },
  { "chapter": "学而", "content": "君子食无求饱，居无求安" },
  { "chapter": "学而", "content": "敏于事而慎于言" },
  { "chapter": "学而", "content": "就有道而正焉" },

  { "chapter": "为政", "content": "为政以德，譬如北辰居其所而众星共之" },
  { "chapter": "为政", "content": "诗三百，一言以蔽之，曰思无邪" },
  { "chapter": "为政", "content": "道之以德，齐之以礼，有耻且格" },
  { "chapter": "为政", "content": "吾十有五而志于学" },
  { "chapter": "为政", "content": "三十而立" },
  { "chapter": "为政", "content": "四十而不惑" },
  { "chapter": "为政", "content": "五十而知天命" },
  { "chapter": "为政", "content": "六十而耳顺" },
  { "chapter": "为政", "content": "七十而从心所欲不逾矩" },
  { "chapter": "为政", "content": "视其所以，观其所由，察其所安" },
  { "chapter": "为政", "content": "温故而知新，可以为师矣" },
  { "chapter": "为政", "content": "君子不器" },
  { "chapter": "为政", "content": "先行其言而后从之" },
  { "chapter": "为政", "content": "君子周而不比，小人比而不周" },
  { "chapter": "为政", "content": "学而不思则罔，思而不学则殆" },
  { "chapter": "为政", "content": "攻乎异端，斯害也已" },
  { "chapter": "为政", "content": "知之为知之，不知为不知，是知也" },
  { "chapter": "为政", "content": "举直错诸枉，则民服" },
  { "chapter": "为政", "content": "人而无信，不知其可也" },

  { "chapter": "八佾", "content": "人而不仁，如礼何" },
  { "chapter": "八佾", "content": "人而不仁，如乐何" },
  { "chapter": "八佾", "content": "礼，与其奢也，宁俭" },
  { "chapter": "八佾", "content": "丧，与其易也，宁戚" },
  { "chapter": "八佾", "content": "君子无所争，必也射乎" },
  { "chapter": "八佾", "content": "巧笑倩兮，美目盼兮，素以为绚兮" },
  { "chapter": "八佾", "content": "绘事后素" },
  { "chapter": "八佾", "content": "祭如在，祭神如神在" },
  { "chapter": "八佾", "content": "获罪于天，无所祷也" },
  { "chapter": "八佾", "content": "周监于二代，郁郁乎文哉" },
  { "chapter": "八佾", "content": "尽美矣，又尽善也" },

  { "chapter": "里仁", "content": "里仁为美，择不处仁，焉得知" },
  { "chapter": "里仁", "content": "不仁者不可以久处约，不可以长处乐" },
  { "chapter": "里仁", "content": "仁者安仁，知者利仁" },
  { "chapter": "里仁", "content": "唯仁者能好人，能恶人" },
  { "chapter": "里仁", "content": "苟志于仁矣，无恶也" },
  { "chapter": "里仁", "content": "富与贵是人之所欲也，不以其道得之，不处也" },
  { "chapter": "里仁", "content": "贫与贱是人之所恶也，不以其道得之，不去也" },
  { "chapter": "里仁", "content": "君子去仁，恶乎成名" },
  { "chapter": "里仁", "content": "君子无终食之间违仁" },
  { "chapter": "里仁", "content": "造次必于是，颠沛必于是" },
  { "chapter": "里仁", "content": "我未见好仁者，恶不仁者" },
  { "chapter": "里仁", "content": "朝闻道，夕死可矣" },
  { "chapter": "里仁", "content": "士志于道，而耻恶衣恶食者，未足与议也" },
  { "chapter": "里仁", "content": "君子之于天下也，无适也，无莫也，义之与比" },
  { "chapter": "里仁", "content": "君子怀德，小人怀土" },
  { "chapter": "里仁", "content": "君子怀刑，小人怀惠" },
  { "chapter": "里仁", "content": "君子喻于义，小人喻于利" },
  { "chapter": "里仁", "content": "见贤思齐焉，见不贤而内自省也" },
  { "chapter": "里仁", "content": "事父母几谏，见志不从，又敬不违" },
  { "chapter": "里仁", "content": "父母在，不远游，游必有方" },
  { "chapter": "里仁", "content": "德不孤，必有邻" },
  { "chapter": "里仁", "content": "事君数，斯辱矣；朋友数，斯疏矣" },

  { "chapter": "公冶长", "content": "朽木不可雕也，粪土之墙不可圬也" },
  { "chapter": "公冶长", "content": "始吾于人也，听其言而信其行" },
  { "chapter": "公冶长", "content": "今吾于人也，听其言而观其行" },
  { "chapter": "公冶长", "content": "敏而好学，不耻下问" },
  { "chapter": "公冶长", "content": "有君子之道四焉：其行己也恭，其事上也敬，其养民也惠，其使民也义" },
  { "chapter": "公冶长", "content": "质胜文则野，文胜质则史" },
  { "chapter": "公冶长", "content": "文质彬彬，然后君子" },
  { "chapter": "公冶长", "content": "十室之邑，必有忠信如丘者焉" },
  { "chapter": "公冶长", "content": "老者安之，朋友信之，少者怀之" },
  { "chapter": "公冶长", "content": "巧言令色足恭，左丘明耻之，丘亦耻之" },

  { "chapter": "雍也", "content": "雍也可使南面" },
  { "chapter": "雍也", "content": "居敬而行简，以临其民" },
  { "chapter": "雍也", "content": "不迁怒，不贰过" },
  { "chapter": "雍也", "content": "一箪食，一瓢饮，在陋巷，人不堪其忧，回也不改其乐" },
  { "chapter": "雍也", "content": "力不足者，中道而废，今女画" },
  { "chapter": "雍也", "content": "女为君子儒，无为小人儒" },
  { "chapter": "雍也", "content": "务民之义，敬鬼神而远之，可谓知矣" },
  { "chapter": "雍也", "content": "仁者先难而后获，可谓仁矣" },
  { "chapter": "雍也", "content": "知者乐水，仁者乐山" },
  { "chapter": "雍也", "content": "知者动，仁者静" },
  { "chapter": "雍也", "content": "知者乐，仁者寿" },
  { "chapter": "雍也", "content": "君子博学于文，约之以礼，亦可以弗畔矣夫" },
  { "chapter": "雍也", "content": "中庸之为德也，其至矣乎" },
  { "chapter": "雍也", "content": "夫仁者，己欲立而立人，己欲达而达人" },
  { "chapter": "雍也", "content": "能近取譬，可谓仁之方也已" },

  { "chapter": "述而", "content": "述而不作，信而好古" },
  { "chapter": "述而", "content": "默而识之，学而不厌，诲人不倦" },
  { "chapter": "述而", "content": "德之不修，学之不讲，闻义不能徙，不善不能改，是吾忧也" },
  { "chapter": "述而", "content": "志于道，据于德，依于仁，游于艺" },
  { "chapter": "述而", "content": "自行束脩以上，吾未尝无诲焉" },
  { "chapter": "述而", "content": "不愤不启，不悱不发" },
  { "chapter": "述而", "content": "举一隅不以三隅反，则不复也" },
  { "chapter": "述而", "content": "用之则行，舍之则藏" },
  { "chapter": "述而", "content": "富而可求也，虽执鞭之士，吾亦为之" },
  { "chapter": "述而", "content": "饭疏食饮水，曲肱而枕之，乐亦在其中矣" },
  { "chapter": "述而", "content": "不义而富且贵，于我如浮云" },
  { "chapter": "述而", "content": "发愤忘食，乐以忘忧，不知老之将至云尔" },
  { "chapter": "述而", "content": "我非生而知之者，好古敏以求之者也" },
  { "chapter": "述而", "content": "三人行，必有我师焉" },
  { "chapter": "述而", "content": "择其善者而从之，其不善者而改之" },
  { "chapter": "述而", "content": "天生德于予，桓魋其如予何" },
  { "chapter": "述而", "content": "君子坦荡荡，小人长戚戚" },
  { "chapter": "述而", "content": "恭而安" },

  { "chapter": "泰伯", "content": "泰伯其可谓至德也已矣" },
  { "chapter": "泰伯", "content": "三以天下让，民无得而称焉" },
  { "chapter": "泰伯", "content": "士不可以不弘毅，任重而道远" },
  { "chapter": "泰伯", "content": "仁以为己任，不亦重乎" },
  { "chapter": "泰伯", "content": "死而后已，不亦远乎" },
  { "chapter": "泰伯", "content": "兴于诗，立于礼，成于乐" },
  { "chapter": "泰伯", "content": "民可使由之，不可使知之" },
  { "chapter": "泰伯", "content": "笃信好学，守死善道" },
  { "chapter": "泰伯", "content": "危邦不入，乱邦不居" },
  { "chapter": "泰伯", "content": "天下有道则见，无道则隐" },
  { "chapter": "泰伯", "content": "不在其位，不谋其政" },
  { "chapter": "泰伯", "content": "学如不及，犹恐失之" },
  { "chapter": "泰伯", "content": "巍巍乎，舜禹之有天下也而不与焉" },

  { "chapter": "子罕", "content": "子罕言利，与命，与仁" },
  { "chapter": "子罕", "content": "博学而无所成名" },
  { "chapter": "子罕", "content": "毋意，毋必，毋固，毋我" },
  { "chapter": "子罕", "content": "文王既没，文不在兹乎" },
  { "chapter": "子罕", "content": "天之将丧斯文也，后死者不得与于斯文也" },
  { "chapter": "子罕", "content": "大哉孔子，博学而无所成名" },
  { "chapter": "子罕", "content": "颜渊喟然叹曰：仰之弥高，钻之弥坚" },
  { "chapter": "子罕", "content": "循循然善诱人" },
  { "chapter": "子罕", "content": "欲罢不能，既竭吾才" },
  { "chapter": "子罕", "content": "如有所立卓尔，虽欲从之，末由也已" },
  { "chapter": "子罕", "content": "三军可夺帅也，匹夫不可夺志也" },
  { "chapter": "子罕", "content": "岁寒，然后知松柏之后凋也" },
  { "chapter": "子罕", "content": "知者不惑，仁者不忧，勇者不惧" },
  { "chapter": "子罕", "content": "可与共学，未可与适道" },
  { "chapter": "子罕", "content": "可与适道，未可与立" },
  { "chapter": "子罕", "content": "可与立，未可与权" },
  { "chapter": "子罕", "content": "何陋之有" },

  { "chapter": "乡党", "content": "孔子于乡党，恂恂如也，似不能言者" },
  { "chapter": "乡党", "content": "其在宗庙朝廷，便便言，唯谨尔" },
  { "chapter": "乡党", "content": "朝，与下大夫言，侃侃如也" },
  { "chapter": "乡党", "content": "与上大夫言，誾誾如也" },
  { "chapter": "乡党", "content": "君在，踧踖如也，与与如也" },
  { "chapter": "乡党", "content": "食不语，寝不言" },

  { "chapter": "先进", "content": "先进于礼乐，野人也" },
  { "chapter": "先进", "content": "后进于礼乐，君子也" },
  { "chapter": "先进", "content": "如用之，则吾从先进" },
  { "chapter": "先进", "content": "德行：颜渊、闵子骞、冉伯牛、仲弓" },
  { "chapter": "先进", "content": "言语：宰我、子贡" },
  { "chapter": "先进", "content": "政事：冉有、季路" },
  { "chapter": "先进", "content": "文学：子游、子夏" },
  { "chapter": "先进", "content": "回也非助我者也，于吾言无所不说" },
  { "chapter": "先进", "content": "南容三复白圭，孔子以其兄之子妻之" },
  { "chapter": "先进", "content": "未能事人，焉能事鬼" },
  { "chapter": "先进", "content": "未知生，焉知死" },
  { "chapter": "先进", "content": "过犹不及" },
  { "chapter": "先进", "content": "吾与点也" },
  { "chapter": "先进", "content": "暮春者，春服既成，冠者五六人，童子六七人，浴乎沂，风乎舞雩，咏而归" },

  { "chapter": "颜渊", "content": "克己复礼为仁" },
  { "chapter": "颜渊", "content": "一日克己复礼，天下归仁焉" },
  { "chapter": "颜渊", "content": "非礼勿视，非礼勿听，非礼勿言，非礼勿动" },
  { "chapter": "颜渊", "content": "己所不欲，勿施于人" },
  { "chapter": "颜渊", "content": "内省不疚，夫何忧何惧" },
  { "chapter": "颜渊", "content": "四海之内皆兄弟也" },
  { "chapter": "颜渊", "content": "君子敬而无失，与人恭而有礼" },
  { "chapter": "颜渊", "content": "君子以文会友，以友辅仁" },
  { "chapter": "颜渊", "content": "君子之德风，小人之德草" },
  { "chapter": "颜渊", "content": "草上之风必偃" },
  { "chapter": "颜渊", "content": "质直而好义，察言而观色" },
  { "chapter": "颜渊", "content": "夫达也者，质直而好义" },
  { "chapter": "颜渊", "content": "居之无倦，行之以忠" },
  { "chapter": "颜渊", "content": "博学于文，约之以礼" },

  { "chapter": "子路", "content": "其身正，不令而行" },
  { "chapter": "子路", "content": "其身不正，虽令不从" },
  { "chapter": "子路", "content": "先之，劳之" },
  { "chapter": "子路", "content": "无欲速，无见小利" },
  { "chapter": "子路", "content": "欲速则不达，见小利则大事不成" },
  { "chapter": "子路", "content": "言必信，行必果" },
  { "chapter": "子路", "content": "切切偲偲，怡怡如也" },
  { "chapter": "子路", "content": "士而怀居，不足以为士矣" },
  { "chapter": "子路", "content": "君子和而不同，小人同而不和" },
  { "chapter": "子路", "content": "君子泰而不骄，小人骄而不泰" },
  { "chapter": "子路", "content": "刚毅木讷近仁" },
  { "chapter": "子路", "content": "善人教民七年，亦可以即戎矣" },
  { "chapter": "子路", "content": "以不教民战，是谓弃之" },

  { "chapter": "宪问", "content": "克伐怨欲不行焉，可以为仁矣" },
  { "chapter": "宪问", "content": "士而怀居，不足以为士" },
  { "chapter": "宪问", "content": "邦有道，谷；邦无道，谷，耻也" },
  { "chapter": "宪问", "content": "有德者必有言，有言者不必有德" },
  { "chapter": "宪问", "content": "仁者必有勇，勇者不必有仁" },
  { "chapter": "宪问", "content": "爱之，能勿劳乎" },
  { "chapter": "宪问", "content": "忠焉，能勿诲乎" },
  { "chapter": "宪问", "content": "贫而无怨难，富而无骄易" },
  { "chapter": "宪问", "content": "见危授命，久要不忘平生之言" },
  { "chapter": "宪问", "content": "其言之不怍，则为之也难" },
  { "chapter": "宪问", "content": "君子上达，小人下达" },
  { "chapter": "宪问", "content": "古之学者为己，今之学者为人" },
  { "chapter": "宪问", "content": "不患人之不己知，患其不能也" },
  { "chapter": "宪问", "content": "以直报怨，以德报德" },
  { "chapter": "宪问", "content": "修己以敬" },
  { "chapter": "宪问", "content": "修己以安人" },
  { "chapter": "宪问", "content": "修己以安百姓" },
  { "chapter": "宪问", "content": "幼而不孙弟，长而无述焉，老而不死，是为贼" },

  { "chapter": "卫灵公", "content": "志士仁人，无求生以害仁，有杀身以成仁" },
  { "chapter": "卫灵公", "content": "工欲善其事，必先利其器" },
  { "chapter": "卫灵公", "content": "人无远虑，必有近忧" },
  { "chapter": "卫灵公", "content": "躬自厚而薄责于人，则远怨矣" },
  { "chapter": "卫灵公", "content": "不以言举人，不以人废言" },
  { "chapter": "卫灵公", "content": "有一言而可以终身行之者乎" },
  { "chapter": "卫灵公", "content": "其恕乎，己所不欲，勿施于人" },
  { "chapter": "卫灵公", "content": "吾之于人也，谁毁谁誉" },
  { "chapter": "卫灵公", "content": "巧言乱德，小不忍则乱大谋" },
  { "chapter": "卫灵公", "content": "众恶之，必察焉；众好之，必察焉" },
  { "chapter": "卫灵公", "content": "人能弘道，非道弘人" },
  { "chapter": "卫灵公", "content": "过而不改，是谓过矣" },
  { "chapter": "卫灵公", "content": "吾尝终日不食，终夜不寝，以思，无益，不如学也" },
  { "chapter": "卫灵公", "content": "君子谋道不谋食" },
  { "chapter": "卫灵公", "content": "君子忧道不忧贫" },
  { "chapter": "卫灵公", "content": "知及之，仁不能守之，虽得之，必失之" },
  { "chapter": "卫灵公", "content": "当仁不让于师" },
  { "chapter": "卫灵公", "content": "有教无类" },
  { "chapter": "卫灵公", "content": "道不同，不相为谋" },
  { "chapter": "卫灵公", "content": "辞达而已矣" },

  { "chapter": "季氏", "content": "不患寡而患不均，不患贫而患不安" },
  { "chapter": "季氏", "content": "盖均无贫，和无寡，安无倾" },
  { "chapter": "季氏", "content": "天下有道，则礼乐征伐自天子出" },
  { "chapter": "季氏", "content": "天下无道，则礼乐征伐自诸侯出" },
  { "chapter": "季氏", "content": "益者三友，损者三友" },
  { "chapter": "季氏", "content": "友直，友谅，友多闻，益矣" },
  { "chapter": "季氏", "content": "益者三乐，损者三乐" },
  { "chapter": "季氏", "content": "乐节礼乐，乐道人之善，乐多贤友，益矣" },
  { "chapter": "季氏", "content": "侍于君子有三愆" },
  { "chapter": "季氏", "content": "君子有三戒" },
  { "chapter": "季氏", "content": "少之时，血气未定，戒之在色" },
  { "chapter": "季氏", "content": "及其壮也，血气方刚，戒之在斗" },
  { "chapter": "季氏", "content": "及其老也，血气既衰，戒之在得" },
  { "chapter": "季氏", "content": "君子有九思：视思明，听思聪，色思温，貌思恭，言思忠，事思敬，疑思问，忿思难，见得思义" },
  { "chapter": "季氏", "content": "见善如不及，见不善如探汤" },
  { "chapter": "季氏", "content": "隐居以求其志，行义以达其道" },

  { "chapter": "阳货", "content": "性相近也，习相远也" },
  { "chapter": "阳货", "content": "唯上知与下愚不移" },
  { "chapter": "阳货", "content": "恭则不侮，宽则得众，信则人任焉，敏则有功，惠则足以使人" },
  { "chapter": "阳货", "content": "能行五者于天下为仁矣" },
  { "chapter": "阳货", "content": "好仁不好学，其蔽也愚" },
  { "chapter": "阳货", "content": "好知不好学，其蔽也荡" },
  { "chapter": "阳货", "content": "好信不好学，其蔽也贼" },
  { "chapter": "阳货", "content": "好直不好学，其蔽也绞" },
  { "chapter": "阳货", "content": "好勇不好学，其蔽也乱" },
  { "chapter": "阳货", "content": "好刚不好学，其蔽也狂" },
  { "chapter": "阳货", "content": "六言六蔽" },
  { "chapter": "阳货", "content": "小子何莫学夫诗" },
  { "chapter": "阳货", "content": "诗可以兴，可以观，可以群，可以怨" },
  { "chapter": "阳货", "content": "饱食终日，无所用心，难矣哉" },
  { "chapter": "阳货", "content": "君子义以为上" },
  { "chapter": "阳货", "content": "君子有勇而无义为乱，小人有勇而无义为盗" },

  { "chapter": "微子", "content": "鸟兽不可与同群，吾非斯人之徒与而谁与" },
  { "chapter": "微子", "content": "天下有道，丘不与易也" },
  { "chapter": "微子", "content": "往者不可谏，来者犹可追" },
  { "chapter": "微子", "content": "楚狂接舆歌而过孔子曰：凤兮凤兮，何德之衰" },
  { "chapter": "微子", "content": "无求备于一人" },
  { "chapter": "微子", "content": "大德不逾闲，小德出入可也" },
  { "chapter": "微子", "content": "故旧无大故，则不弃也" },

  { "chapter": "子张", "content": "士见危致命，见得思义" },
  { "chapter": "子张", "content": "祭思敬，丧思哀，其可已矣" },
  { "chapter": "子张", "content": "执德不弘，信道不笃，焉能为有，焉能为亡" },
  { "chapter": "子张", "content": "君子尊贤而容众，嘉善而矜不能" },
  { "chapter": "子张", "content": "日知其所亡，月无忘其所能" },
  { "chapter": "子张", "content": "博学而笃志，切问而近思，仁在其中矣" },
  { "chapter": "子张", "content": "百工居肆以成其事，君子学以致其道" },
  { "chapter": "子张", "content": "小人之过也必文" },
  { "chapter": "子张", "content": "君子有三变：望之俨然，即之也温，听其言也厉" },
  { "chapter": "子张", "content": "君子信而后劳其民" },
  { "chapter": "子张", "content": "大德不逾闲，小德出入可也" },
  { "chapter": "子张", "content": "学而优则仕" },
  { "chapter": "子张", "content": "仕而优则学" },
  { "chapter": "子张", "content": "生乎吾前，其闻道也固先乎吾，吾从而师之" },
  { "chapter": "子张", "content": "丧致乎哀而止" },

  { "chapter": "尧曰", "content": "允执其中" },
  { "chapter": "尧曰", "content": "四海困穷，天禄永终" },
  { "chapter": "尧曰", "content": "兴灭国，继绝世，举逸民，天下之民归心焉" },
  { "chapter": "尧曰", "content": "所重：民、食、丧、祭" },
  { "chapter": "尧曰", "content": "宽则得众，信则民任焉，敏则有功，公则说" },
  { "chapter": "尧曰", "content": "不知命，无以为君子也" },
  { "chapter": "尧曰", "content": "不知礼，无以立也" },
  { "chapter": "尧曰", "content": "不知言，无以知人也" }
]